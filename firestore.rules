rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.uid == "zKV67M5hJRdh07GawmTZSJtxKA92" ||
         request.auth.token.email == "betterleaf2100@gmail.com");
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['portfolio_credits', 'role', 'email', 'last_reset_date']) &&
             (data.portfolio_credits is int) &&
             (data.role in ['admin', 'vip', 'student', 'trial']) &&
             (data.email is string) &&
             (data.last_reset_date is string);
    }

    function isValidUserSettings(data) {
      return data.keys().hasOnly(['currency', 'language', 'simulationParams', 'updatedAt']) &&
             (data.currency in ['USD', 'TWD', 'HKD', 'CNY', 'MYR', 'SGD', 'JPY', 'EUR', 'GBP']) &&
             (data.language in ['zh', 'en']) &&
             (data.simulationParams is map) &&
             (data.simulationParams.annualReturn is number) &&
             (data.simulationParams.years is number) &&
             (data.simulationParams.monthlyExpenses is number) &&
             (data.simulationParams.monthlyInvestment is number) &&
             (data.simulationParams.inflationRate is number) &&
             (data.simulationParams.useCalculatedGoal is bool);
    }

    // User profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data)) || isAdmin();
      
      match /settings/{configId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) && isValidUserSettings(request.resource.data);
      }

      match /Planner/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }
    
    // Investment Planner (Root level as requested)
    match /Planner/{planType}/Data/{dataId} {
      allow read, write: if isAuthenticated();
    }
    
    // Whitelist for roles
    match /whitelisted_users/{email} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // App settings (Risk Profiles, etc.)
    match /apps/{appId} {
      allow read, write: if isAuthenticated(); 
      
      match /Planner/{riskId}/Data/{dataId} {
        allow read, write: if isAuthenticated();
      }

      match /global/{document=**} {
        allow read: if isAuthenticated();
      }
    }

    // Global data (Portfolio, etc.)
    match /apps/{appId}/global/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
